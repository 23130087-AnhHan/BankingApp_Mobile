<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Banking Demo</string>
    <style name="ActionTile">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">98dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/action_tile_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">#17324D</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ActionTileWide" parent="ActionTile">
        <item name="android:layout_width">match_parent</item>
    </style>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F3F6FA</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:colorAccent">#1F7A53</item>
    </style>
    <style name="Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">#17324D</item>
        <item name="android:textColorHint">#8A94A6</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="MutedText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#667085</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="PageTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#17324D</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Panel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:background">@drawable/panel_bg</item>
        <item name="android:padding">16dp</item>
    </style>
    <style name="PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/button_bg</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="ResultBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:background">@drawable/panel_bg</item>
        <item name="android:minHeight">90dp</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#17324D</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="SecondaryButton" parent="PrimaryButton">
        <item name="android:backgroundTint">#17324D</item>
    </style>
    <style name="SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">#17324D</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>