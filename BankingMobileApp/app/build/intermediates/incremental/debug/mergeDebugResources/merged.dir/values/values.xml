<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="app_background">#F4F7FC</color>
    <color name="bank_blue">#1769E0</color>
    <color name="bank_blue_dark">#0D4FB8</color>
    <color name="bank_blue_soft">#EAF2FF</color>
    <color name="bank_navy">#0B214A</color>
    <color name="bank_teal">#19A7A0</color>
    <color name="border">#DDE5F0</color>
    <color name="success">#11845B</color>
    <color name="success_soft">#E5F7EF</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_alt">#F8FAFD</color>
    <color name="text_on_primary">#FFFFFF</color>
    <color name="text_on_primary_muted">#D8E6FF</color>
    <color name="text_primary">#12223B</color>
    <color name="text_secondary">#66758C</color>
    <color name="warning">#B35C00</color>
    <color name="warning_soft">#FFF3E3</color>
    <string name="app_name">Banking Demo</string>
    <style name="ActionTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">112dp</item>
        <item name="android:background">@drawable/action_tile_bg</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:elevation">1dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">14dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ActionTileWide" parent="ActionTile">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">78dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAlignment">viewStart</item>
    </style>
    <style name="AmountInput" parent="Input">
        <item name="android:layout_height">72dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/bank_navy</item>
        <item name="android:textSize">26sp</item>
    </style>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:colorAccent">@color/bank_blue</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="FieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>
    <style name="HelperText" parent="MutedText">
        <item name="android:layout_marginTop">-6dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="MutedText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="PageTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/bank_navy</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Panel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:background">@drawable/panel_bg</item>
        <item name="android:elevation">2dp</item>
        <item name="android:padding">18dp</item>
    </style>
    <style name="PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/button_bg</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="ResultBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:background">@drawable/result_box_bg</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:minHeight">88dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="SecondaryButton" parent="PrimaryButton">
        <item name="android:background">@drawable/button_secondary_bg</item>
        <item name="android:textColor">@color/bank_blue</item>
    </style>
    <style name="SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="WarningButton" parent="PrimaryButton">
        <item name="android:background">@drawable/button_warning_bg</item>
        <item name="android:textColor">@color/warning</item>
    </style>
</resources>