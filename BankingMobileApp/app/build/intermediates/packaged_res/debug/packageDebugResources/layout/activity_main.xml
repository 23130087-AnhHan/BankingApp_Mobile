<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            style="@style/MutedText"
            android:text="Good day" />

        <TextView
            style="@style/PageTitle"
            android:text="My Banking" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/balance_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/userIdText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User ID 1"
                    android:textColor="#DCE8F2"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_pill_bg"
                    android:text="Syncing"
                    android:textColor="#1F7A53"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Available balance"
                android:textColor="#DCE8F2"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/balanceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Loading..."
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/accountNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No account selected"
                android:textColor="#DCE8F2"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshButton"
            style="@style/SecondaryButton"
            android:text="Refresh account" />

        <TextView
            style="@style/SectionTitle"
            android:layout_marginTop="22dp"
            android:text="Quick actions" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/registerTile"
                style="@style/ActionTileWide"
                android:text="Register\nCreate customer" />

            <TextView
                android:id="@+id/accountTile"
                style="@style/ActionTile"
                android:text="Account\nOpen and activate" />

            <TextView
                android:id="@+id/depositTile"
                style="@style/ActionTileWide"
                android:text="Cash\nDeposit or withdraw" />

            <TextView
                android:id="@+id/transferTile"
                style="@style/ActionTileWide"
                android:text="Transfer\nSend money" />

            <TextView
                android:id="@+id/historyTile"
                style="@style/ActionTileWide"
                android:text="Transaction history\nReview account activity" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
