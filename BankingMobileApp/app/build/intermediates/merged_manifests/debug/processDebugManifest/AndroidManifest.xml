<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bankingmobileapp"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true" >
        <activity
            android:name="com.example.bankingmobileapp.WelcomeActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="com.example.bankingmobileapp.QuickLoginActivity" />
        <activity android:name="com.example.bankingmobileapp.LoginActivity" />
        <activity android:name="com.example.bankingmobileapp.HistoryActivity" />
        <activity android:name="com.example.bankingmobileapp.TransferActivity" />
        <activity android:name="com.example.bankingmobileapp.TransactionActivity" />
        <activity android:name="com.example.bankingmobileapp.AccountActivity" />
        <activity android:name="com.example.bankingmobileapp.RegisterActivity" />
        <activity android:name="com.example.bankingmobileapp.MainActivity" />
    </application>

</manifest>