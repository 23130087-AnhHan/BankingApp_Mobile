<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="@drawable/account_header_bg"
            android:padding="20dp">

            <Button
                android:id="@+id/backButton"
                style="@style/NluHeaderButton"
                android:text="‹" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Quản lý mã PIN"
                    android:textColor="@android:color/white"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Bảo mật thanh toán"
                    android:textColor="@color/nlu_mint"
                    android:textSize="13sp" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-42dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/pin_status_bg"
            android:elevation="7dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="17dp">

            <TextView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/main_notification_bg"
                android:gravity="center"
                android:text="✓"
                android:textColor="@color/nlu_green_deep"
                android:textSize="23sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="13dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Trạng thái bảo mật"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Đang kiểm tra PIN..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/account_info_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Thiết lập PIN"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="18dp"
                android:text="PIN gồm đúng 6 chữ số và được dùng để xác nhận giao dịch."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView style="@style/FieldLabel" android:text="PIN hiện tại" />
            <EditText
                android:id="@+id/currentPinInput"
                style="@style/PinInput"
                android:hint="Nhập PIN hiện tại"
                android:inputType="numberPassword" />

            <TextView style="@style/FieldLabel" android:text="PIN mới" />
            <EditText
                android:id="@+id/newPinInput"
                style="@style/PinInput"
                android:hint="••••••"
                android:inputType="numberPassword" />

            <TextView style="@style/FieldLabel" android:text="Nhập lại PIN mới" />
            <EditText
                android:id="@+id/confirmPinInput"
                style="@style/PinInput"
                android:hint="••••••"
                android:inputType="numberPassword" />

            <Button
                android:id="@+id/savePinButton"
                style="@style/NluPrimaryButton"
                android:text="Lưu mã PIN" />

            <Button
                android:id="@+id/clearPinButton"
                style="@style/NluDangerButton"
                android:text="Xóa mã PIN hiện tại" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
