<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout style="@style/ScreenRoot">

        <TextView
            style="@style/MutedText"
            android:text="Danh bạ chuyển tiền" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Người thụ hưởng" />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Thêm người thụ hưởng" />

            <TextView
                style="@style/FieldLabel"
                android:text="Ngân hàng" />

            <EditText
                android:id="@+id/bankNameInput"
                style="@style/Input"
                android:hint="Ví dụ: NLU Banking"
                android:inputType="textCapWords" />

            <TextView
                style="@style/FieldLabel"
                android:text="Số tài khoản" />

            <EditText
                android:id="@+id/beneficiaryAccountInput"
                style="@style/Input"
                android:hint="Nhập số tài khoản"
                android:inputType="number" />

            <TextView
                style="@style/FieldLabel"
                android:text="Tên chủ tài khoản" />

            <EditText
                android:id="@+id/accountHolderNameInput"
                style="@style/Input"
                android:hint="Nhập tên chủ tài khoản"
                android:inputType="textCapWords" />

            <TextView
                style="@style/FieldLabel"
                android:text="Tên gợi nhớ" />

            <EditText
                android:id="@+id/nicknameInput"
                style="@style/Input"
                android:hint="Ví dụ: Anh Nam, Tiền nhà"
                android:inputType="textCapWords" />

            <Button
                android:id="@+id/saveBeneficiaryButton"
                style="@style/PrimaryButton"
                android:text="Lưu người thụ hưởng" />
        </LinearLayout>

        <TextView
            android:id="@+id/beneficiaryResultText"
            style="@style/ResultBox"
            android:text="Danh sách người thụ hưởng sẽ hiển thị tại đây." />

        <Button
            android:id="@+id/refreshBeneficiaryButton"
            style="@style/SecondaryButton"
            android:text="Làm mới danh sách" />

        <LinearLayout
            android:id="@+id/beneficiaryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
