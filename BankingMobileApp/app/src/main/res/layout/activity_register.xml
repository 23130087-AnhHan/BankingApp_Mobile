<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        style="@style/ScreenRoot">

        <TextView
            style="@style/MutedText"
            android:text="NLU Banking" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Tạo hồ sơ khách hàng" />

        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Sau khi tạo hồ sơ, bạn cần nhập mã OTP được gửi qua email để hoàn tất đăng ký." />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Thông tin cá nhân" />

            <TextView
                style="@style/FieldLabel"
                android:text="Tên" />

            <EditText
                android:id="@+id/firstNameInput"
                style="@style/Input"
                android:hint="Ví dụ: An"
                android:inputType="textCapWords" />

            <TextView
                style="@style/FieldLabel"
                android:text="Họ và tên đệm" />

            <EditText
                android:id="@+id/lastNameInput"
                style="@style/Input"
                android:hint="Ví dụ: Nguyễn Văn"
                android:inputType="textCapWords" />

            <TextView
                style="@style/FieldLabel"
                android:text="Số điện thoại" />

            <EditText
                android:id="@+id/phoneInput"
                style="@style/Input"
                android:hint="09xx xxx xxx"
                android:inputType="phone" />

            <TextView
                android:id="@+id/phoneErrorText"
                style="@style/HelperText"
                android:textColor="@color/danger"
                android:visibility="gone" />

            <TextView
                style="@style/FieldLabel"
                android:text="Email" />

            <EditText
                android:id="@+id/emailInput"
                style="@style/Input"
                android:hint="tenban@email.com"
                android:inputType="textEmailAddress" />

            <TextView
                android:id="@+id/emailErrorText"
                style="@style/HelperText"
                android:textColor="@color/danger"
                android:visibility="gone" />

            <TextView
                style="@style/FieldLabel"
                android:text="Mật khẩu" />

            <EditText
                android:id="@+id/passwordInput"
                style="@style/Input"
                android:drawableEnd="@drawable/ic_visibility_off"
                android:hint="Tạo mật khẩu đăng nhập"
                android:inputType="textPassword" />

            <TextView
                style="@style/FieldLabel"
                android:text="Nhập lại mật khẩu" />

            <EditText
                android:id="@+id/confirmPasswordInput"
                style="@style/Input"
                android:drawableEnd="@drawable/ic_visibility_off"
                android:hint="Nhập lại mật khẩu"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/registerButton"
                style="@style/PrimaryButton"
                android:text="Tạo hồ sơ" />

            <Button
                android:id="@+id/loginButton"
                style="@style/TextButton"
                android:text="Đã có hồ sơ? Đăng nhập" />
        </LinearLayout>

        <TextView
            android:id="@+id/resultText"
            style="@style/ResultBox"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
