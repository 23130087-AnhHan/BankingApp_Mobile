<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout style="@style/ScreenRoot">

        <TextView
            style="@style/MutedText"
            android:text="Biên lai" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Chi tiết giao dịch" />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                android:id="@+id/receiptStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Đang tải"
                android:textColor="@color/success"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/receiptAmountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="--"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/receiptMessageText"
                style="@style/MutedText"
                android:layout_marginTop="8dp"
                android:text="Đang tải chi tiết giao dịch..." />
        </LinearLayout>

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Thông tin biên lai" />

            <LinearLayout
                android:id="@+id/receiptRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/backButton"
            style="@style/SecondaryButton"
            android:text="Quay lại lịch sử" />
    </LinearLayout>
</ScrollView>
