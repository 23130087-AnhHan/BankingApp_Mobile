<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        style="@style/ScreenRoot">

        <TextView
            style="@style/MutedText"
            android:text="NLU Banking" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Đặt lại mật khẩu" />

        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Nhập mật khẩu mới cho tài khoản của bạn để hoàn tất đặt lại mật khẩu." />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Mật khẩu mới" />

            <TextView
                style="@style/FieldLabel"
                android:text="Mật khẩu mới" />

            <EditText
                android:id="@+id/passwordInput"
                style="@style/Input"
                android:drawableEnd="@drawable/ic_visibility_off"
                android:hint="Nhập mật khẩu mới"
                android:inputType="textPassword" />

            <TextView
                style="@style/FieldLabel"
                android:text="Nhập lại mật khẩu" />

            <EditText
                android:id="@+id/confirmPasswordInput"
                style="@style/Input"
                android:drawableEnd="@drawable/ic_visibility_off"
                android:hint="Nhập lại mật khẩu mới"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/submitButton"
                style="@style/PrimaryButton"
                android:text="Cập nhật mật khẩu" />
        </LinearLayout>

        <TextView
            android:id="@+id/resultText"
            style="@style/ResultBox"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
