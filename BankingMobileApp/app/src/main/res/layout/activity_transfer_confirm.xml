<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="154dp"
            android:background="@drawable/account_header_bg"
            android:padding="20dp">

            <Button
                android:id="@+id/backButton"
                style="@style/NluHeaderButton"
                android:text="‹" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Kiểm tra giao dịch"
                android:textColor="@android:color/white"
                android:textSize="23sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-34dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/transfer_confirm_dark_bg"
            android:elevation="7dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/transfer_info_strip_bg"
                android:lineSpacingExtra="3dp"
                android:padding="14dp"
                android:text="Quý khách vui lòng kiểm tra và xác nhận thông tin giao dịch"
                android:textColor="#EAF8EF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/confirmSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="8dp"
                android:textColor="@android:color/white"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/account_info_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Phương thức xác thực"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/authMethodGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/pinOption"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:buttonTint="@color/nlu_green_deep"
                    android:checked="true"
                    android:text="Nhập mã PIN"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/otpEmailOption"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:buttonTint="@color/nlu_green_deep"
                    android:text="OTP gửi về email"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />
            </RadioGroup>

            <Button
                android:id="@+id/confirmButton"
                style="@style/NluPrimaryButton"
                android:text="Xác nhận" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
