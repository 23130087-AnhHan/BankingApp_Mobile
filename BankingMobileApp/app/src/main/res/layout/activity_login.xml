<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView style="@style/MutedText" android:text="Truy cập tài khoản" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Đăng nhập" />

        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Phiên bản demo dùng User ID để tra cứu tài khoản qua backend. Mật khẩu được kiểm tra tối thiểu ở phía ứng dụng vì backend chưa có endpoint login thật." />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Thông tin truy cập" />

            <TextView
                style="@style/FieldLabel"
                android:text="User ID" />

            <EditText
                android:id="@+id/userIdInput"
                style="@style/Input"
                android:hint="Nhập User ID"
                android:inputType="number" />

            <TextView
                style="@style/FieldLabel"
                android:text="Mật khẩu" />

            <EditText
                android:id="@+id/passwordInput"
                style="@style/Input"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/loginButton"
                style="@style/PrimaryButton"
                android:text="Đăng nhập" />
        </LinearLayout>

        <Button
            android:id="@+id/registerButton"
            style="@style/SecondaryButton"
            android:text="Chưa có hồ sơ? Đăng ký" />

        <Button
            android:id="@+id/forgotPasswordButton"
            style="@style/SecondaryButton"
            android:text="Quên mật khẩu?" />

        <TextView
            android:id="@+id/resultText"
            style="@style/ResultBox"
            android:text="Nhập User ID và mật khẩu để đăng nhập phiên bản demo." />
    </LinearLayout>
</ScrollView>
