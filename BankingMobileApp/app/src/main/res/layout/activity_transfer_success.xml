<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-medium"
            android:text="NLU Bank"
            android:textColor="@color/nlu_green_deep"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/transfer_success_card_bg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:background="@drawable/transfer_success_icon_bg"
                android:gravity="center"
                android:text="✓"
                android:textColor="#183816"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Giao dịch thành công!"
                android:textColor="@android:color/white"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/successAmountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:textColor="#CFFF3F"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/successTimeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="#DCEBE4"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/transfer_success_detail_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/successToAccountText" style="@style/TransferSuccessRow" />
                <TextView android:id="@+id/successRecipientText" style="@style/TransferSuccessRow" />
                <TextView android:id="@+id/successBankText" style="@style/TransferSuccessRow" />
                <TextView android:id="@+id/successNoteText" style="@style/TransferSuccessRow" />
                <TextView android:id="@+id/successReferenceText" style="@style/TransferSuccessRow" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/newTransferButton"
            style="@style/NluPrimaryButton"
            android:layout_marginTop="20dp"
            android:text="Thực hiện giao dịch mới" />

        <Button
            android:id="@+id/homeButton"
            style="@style/TransferSecondaryButton"
            android:layout_marginTop="12dp"
            android:text="Quay về trang chủ" />
    </LinearLayout>
</ScrollView>
