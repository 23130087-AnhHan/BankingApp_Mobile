<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/logout_dialog_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="30dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp">

    <TextView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/logout_warning_bg"
        android:gravity="center"
        android:text="!"
        android:textColor="@android:color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Quý khách có chắc chắn muốn thoát khỏi phiên đăng nhập này không?"
        android:textColor="@android:color/white"
        android:textSize="19sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelLogoutButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/logout_cancel_button_bg"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:text="Đóng"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/confirmLogoutButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/logout_confirm_button_bg"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:text="Đồng ý"
            android:textAllCaps="false"
            android:textColor="#062816"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
