<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        style="@style/ScreenRoot">

        <TextView style="@style/MutedText" android:text="NLU Banking" />
        <TextView style="@style/PageTitle" android:layout_marginTop="2dp" android:text="Mở tài khoản" />
        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Chọn loại tài khoản phù hợp. App sẽ tự dùng thông tin người dùng đang đăng nhập." />

        <LinearLayout style="@style/Panel" android:orientation="vertical">
            <TextView style="@style/SectionTitle" android:text="Loại tài khoản" />

            <RadioGroup
                android:id="@+id/accountTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/checkingAccountOption"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:buttonTint="@color/bank_blue"
                    android:checked="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="Tài khoản thanh toán"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/savingsAccountOption"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:buttonTint="@color/bank_blue"
                    android:fontFamily="sans-serif-medium"
                    android:text="Tài khoản tiết kiệm"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />
            </RadioGroup>

            <Button android:id="@+id/createAccountButton" style="@style/PrimaryButton" android:text="Mở tài khoản" />
        </LinearLayout>

        <Button android:id="@+id/backToDashboardButton" style="@style/SecondaryButton" android:text="Về trang chủ" />

        <TextView
            android:id="@+id/resultText"
            style="@style/ResultBox"
            android:text="Bạn chưa có tài khoản. Chọn loại tài khoản và bấm Mở tài khoản." />
    </LinearLayout>
</ScrollView>
