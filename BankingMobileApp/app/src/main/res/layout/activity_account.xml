<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout style="@style/ScreenRoot">

        <TextView
            style="@style/MutedText"
            android:text="NLU Banking" />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Tài khoản" />

        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Quản lý tài khoản thanh toán chính dùng cho nhận tiền, chuyển tiền và lịch sử giao dịch." />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Tài khoản thanh toán" />

            <TextView
                android:id="@+id/resultText"
                style="@style/ResultBox"
                android:layout_marginTop="0dp"
                android:text="Đang tải tài khoản thanh toán..." />

            <Button
                android:id="@+id/refreshAccountButton"
                style="@style/SecondaryButton"
                android:text="Làm mới thông tin" />
        </LinearLayout>

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/SectionTitle"
                android:text="Thao tác" />

            <Button
                android:id="@+id/transferButton"
                style="@style/PrimaryButton"
                android:text="Chuyển tiền" />

            <Button
                android:id="@+id/historyButton"
                style="@style/SecondaryButton"
                android:text="Xem lịch sử giao dịch" />

            <Button
                android:id="@+id/pinButton"
                style="@style/SecondaryButton"
                android:text="Quản lý mã PIN" />
        </LinearLayout>

        <Button
            android:id="@+id/backToDashboardButton"
            style="@style/TextButton"
            android:text="Về trang chủ" />
    </LinearLayout>
</ScrollView>
