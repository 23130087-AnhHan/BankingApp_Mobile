<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="@drawable/account_header_bg"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp">

            <Button
                android:id="@+id/backToDashboardButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/main_round_icon_bg"
                android:gravity="center"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text="‹"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="34sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Tài khoản"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="NLU Bank"
                    android:textColor="@color/nlu_mint"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/refreshAccountButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/main_round_icon_bg"
                android:gravity="center"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text="↻"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="25sp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-62dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/account_info_card_bg"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÀI KHOẢN THANH TOÁN"
                android:textColor="@color/nlu_green_deep"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/accountHolderValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="Khách hàng NLU"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Số tài khoản"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/accountNumberValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="Đang tải..."
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="16dp"
                android:background="#DCE9E1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số dư khả dụng"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/accountBalanceValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="0 VND"
                        android:textColor="@color/nlu_green_deep"
                        android:textSize="27sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/accountStatusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_pill_bg"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="6dp"
                    android:text="Đang tải"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Đang tải tài khoản thanh toán..."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="Thao tác nhanh"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/transferButton"
            style="@style/AccountPrimaryAction"
            android:drawableStart="@drawable/ic_transfer"
            android:text="Chuyển tiền" />

        <Button
            android:id="@+id/historyButton"
            style="@style/AccountSecondaryAction"
            android:drawableStart="@drawable/ic_history"
            android:text="Lịch sử giao dịch" />

        <Button
            android:id="@+id/pinButton"
            style="@style/AccountSecondaryAction"
            android:drawableStart="@drawable/ic_settings"
            android:text="Quản lý mã PIN" />
    </LinearLayout>
</ScrollView>
