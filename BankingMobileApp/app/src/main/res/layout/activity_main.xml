<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout style="@style/ScreenRoot">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/MutedText"
                    android:text="Xin chào," />

                <TextView
                    style="@style/PageTitle"
                    android:layout_marginTop="2dp"
                    android:text="NLU Banking" />
            </LinearLayout>

            <TextView
                style="@style/BrandMark"
                android:text="NLU" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="196dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/balance_card_bg"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/userIdText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Chưa có khách hàng"
                    android:textColor="@color/text_on_primary_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_pill_bg"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Đang đồng bộ"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Số dư khả dụng"
                android:textColor="@color/text_on_primary_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/balanceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="0 đ"
                android:textColor="@color/text_on_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/accountNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Bạn chưa có tài khoản"
                android:textColor="@color/text_on_primary_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshButton"
            style="@style/SecondaryButton"
            android:layout_marginTop="14dp"
            android:text="Làm mới số dư" />

        <TextView
            style="@style/SectionTitle"
            android:layout_marginTop="24dp"
            android:text="Dịch vụ chính" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/transferTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_transfer"
                android:text="Chuyển tiền" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/accountTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_account"
                android:text="Tài khoản" />
        </LinearLayout>

        <TextView
            android:id="@+id/scanQrTile"
            style="@style/ActionTileWide"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_transfer"
            android:drawablePadding="12dp"
            android:text="Quét QR chuyển tiền" />

        <TextView
            android:id="@+id/historyTile"
            style="@style/ActionTileWide"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_history"
            android:drawablePadding="12dp"
            android:text="Lịch sử giao dịch" />

        <TextView
            android:id="@+id/beneficiaryTile"
            style="@style/ActionTileWide"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_user_add"
            android:drawablePadding="12dp"
            android:text="Người thụ hưởng" />

        <TextView
            android:id="@+id/myQrTile"
            style="@style/ActionTileWide"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_wallet"
            android:drawablePadding="12dp"
            android:text="QR nhận tiền" />

        <TextView
            android:id="@+id/notificationTile"
            style="@style/ActionTileWide"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_wallet"
            android:drawablePadding="12dp"
            android:text="Thông báo" />

        <Button
            android:id="@+id/logoutButton"
            style="@style/TextButton"
            android:layout_marginTop="16dp"
            android:text="Đăng xuất" />
    </LinearLayout>
</ScrollView>
