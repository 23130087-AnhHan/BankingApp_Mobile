<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView
            style="@style/MutedText"
            android:text="Xin chào," />

        <TextView
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Ngân hàng của bạn" />

        <!-- Thẻ tổng quan tài khoản luôn giữ thông tin quan trọng ở đầu màn hình. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="208dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/balance_card_bg"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/userIdText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Khách hàng #1"
                    android:textColor="@color/text_on_primary_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_pill_bg"
                    android:fontFamily="sans-serif-medium"
                    android:text="Đang đồng bộ"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Số dư khả dụng"
                android:textColor="@color/text_on_primary_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/balanceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Đang tải..."
                android:textColor="@color/text_on_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/accountNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Chưa chọn tài khoản"
                android:textColor="@color/text_on_primary_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshButton"
            style="@style/SecondaryButton"
            android:text="Làm mới số dư" />

        <Button
            android:id="@+id/logoutButton"
            style="@style/WarningButton"
            android:text="Đăng xuất" />

        <TextView
            style="@style/SectionTitle"
            android:layout_marginTop="26dp"
            android:text="Giao dịch nhanh" />

        <!-- Lưới 2 x 2 giúp các tác vụ chính có cùng độ ưu tiên thị giác. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/transferTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_transfer"
                android:text="Chuyển tiền" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/depositTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_wallet"
                android:text="Nạp / Rút tiền" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/accountTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_account"
                android:text="Tài khoản" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/historyTile"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_history"
                android:text="Lịch sử" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
