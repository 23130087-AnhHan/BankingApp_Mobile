<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="104dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="229dp"
                android:background="@drawable/main_header_bg"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Banner NLU Bank"
                    android:scaleType="centerCrop"
                    android:src="@drawable/main_banner" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#38002516" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="22dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="22dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:contentDescription="Logo NLU Bank"
                        android:src="@drawable/nlu_logo" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="NLU Bank"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngân hàng số sinh viên"
                            android:textColor="@color/nlu_mint"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/logoutButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/main_round_icon_bg"
                    android:contentDescription="Đăng xuất"
                    android:padding="12dp"
                    android:src="@drawable/ic_logout" />
                </RelativeLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/main_account_card_bg"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/userNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/main_user_badge_bg"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="9dp"
                            android:text="Khách hàng NLU"
                            android:textColor="@color/nlu_green_deep"
                            android:textSize="19sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp">

                        <ImageButton
                            android:id="@+id/notificationTile"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/main_notification_bg"
                            android:contentDescription="Thông báo"
                            android:padding="10dp"
                            android:src="@drawable/ic_notification" />

                        <TextView
                            android:id="@+id/notificationBadge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="end|top"
                            android:layout_marginTop="-2dp"
                            android:layout_marginEnd="-2dp"
                            android:background="@drawable/badge_circle_red"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:text=""
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/userIdText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Số tài khoản"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/accountNumberText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="Đang kiểm tra tài khoản"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/copyAccountButton"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="2dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Sao chép số tài khoản"
                        android:padding="8dp"
                        android:src="@drawable/ic_copy" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Số dư khả dụng"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/balanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="********"
                        android:textColor="@color/nlu_green_deep"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/toggleBalanceButton"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="2dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Hiện số dư"
                        android:padding="8dp"
                        android:src="@drawable/ic_visibility_off" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/status_pill_bg"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Đang đồng bộ"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="sans-serif-medium"
                android:text="Dịch vụ chính"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="12dp"
                android:columnCount="3"
                android:rowCount="2">

                <TextView
                    android:id="@+id/transferTile"
                    style="@style/MainServiceItem"
                    android:layout_columnWeight="1"
                    android:drawableTint="@color/nlu_green_deep"
                    android:drawableTop="@drawable/ic_transfer"
                    android:text="Chuyển\ntiền" />

                <TextView
                    android:id="@+id/beneficiaryTile"
                    style="@style/MainServiceItem"
                    android:layout_columnWeight="1"
                    android:drawableTint="@color/nlu_green_deep"
                    android:drawableTop="@drawable/ic_user_add"
                    android:text="Người thụ\nhưởng" />

                <TextView
                    android:id="@+id/historyTile"
                    style="@style/MainServiceItem"
                    android:layout_columnWeight="1"
                    android:drawableTint="@color/nlu_green_deep"
                    android:drawableTop="@drawable/ic_history"
                    android:text="Lịch sử\ngiao dịch" />

                <TextView
                    android:id="@+id/myQrTile"
                    style="@style/MainServiceItem"
                    android:layout_columnWeight="1"
                    android:drawableTint="@color/nlu_green_deep"
                    android:drawableTop="@drawable/ic_wallet"
                    android:text="QR nhận\ntiền" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/main_bottom_nav_bg"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/productTile"
            style="@style/MainNavItem"
            android:drawableTop="@drawable/ic_products"
            android:text="Sản phẩm" />

        <ImageButton
            android:id="@+id/scanQrTile"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:background="@drawable/main_scan_bg"
            android:contentDescription="Quét QR"
            android:elevation="8dp"
            android:padding="18dp"
            android:src="@drawable/ic_qr_scan" />

        <TextView
            android:id="@+id/accountTile"
            style="@style/MainNavItem"
            android:drawableTop="@drawable/ic_settings"
            android:text="Cài đặt" />
    </LinearLayout>
</FrameLayout>
