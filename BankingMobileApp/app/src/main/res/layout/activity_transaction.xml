<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        style="@style/ScreenRoot">

        <TextView style="@style/MutedText" android:text="Giao dịch tiền mặt" />
        <TextView style="@style/PageTitle" android:layout_marginTop="2dp" android:text="Nạp / Rút tiền" />

        <LinearLayout style="@style/Panel" android:orientation="vertical">
            <TextView style="@style/SectionTitle" android:text="Thông tin giao dịch" />

            <TextView style="@style/FieldLabel" android:text="Số tài khoản" />
            <EditText android:id="@+id/accountNumberInput" style="@style/Input" android:hint="Số tài khoản" android:inputType="number" />

            <TextView style="@style/FieldLabel" android:text="Loại giao dịch" />
            <EditText
                android:id="@+id/transactionTypeInput"
                style="@style/Input"
                android:clickable="false"
                android:focusable="false"
                android:hint="Chọn Nạp tiền hoặc Rút tiền" />

            <TextView style="@style/FieldLabel" android:text="Số tiền" />
            <EditText
                android:id="@+id/amountInput"
                style="@style/AmountInput"
                android:gravity="center_vertical"
                android:hint="0 đ"
                android:inputType="numberDecimal" />

            <TextView style="@style/FieldLabel" android:text="Nội dung" />
            <EditText android:id="@+id/descriptionInput" style="@style/Input" android:hint="Ví dụ: Nap tien tai quay" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/depositButton"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Nạp tiền" />

                <Space android:layout_width="12dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/withdrawButton"
                    style="@style/WarningButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Rút tiền" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/resultText" style="@style/ResultBox" android:text="Kết quả giao dịch sẽ hiển thị tại đây." />
    </LinearLayout>
</ScrollView>
