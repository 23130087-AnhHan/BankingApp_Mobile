<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="176dp"
            android:background="@drawable/account_header_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/main_round_icon_bg"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="NLU"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Xác thực OTP"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Bảo vệ tài khoản NLU Banking"
                    android:textColor="@color/nlu_mint"
                    android:textSize="13sp" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-46dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/account_info_card_bg"
            android:elevation="7dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/transfer_auth_icon_bg"
                android:gravity="center"
                android:text="i"
                android:textColor="#183816"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/otpDestinationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="Mã OTP đã được gửi đến email:"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/otpCountdownText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Mã OTP còn hiệu lực trong 05:00"
                android:textColor="@color/nlu_green_deep"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/otpInput"
                style="@style/PinInput"
                android:layout_marginTop="20dp"
                android:digits="0123456789"
                android:hint="Nhập 6 chữ số"
                android:inputType="number"
                android:maxLength="6" />

            <Button
                android:id="@+id/verifyOtpButton"
                style="@style/NluPrimaryButton"
                android:text="Xác thực" />

            <Button
                android:id="@+id/resendOtpButton"
                style="@style/TransferSecondaryButton"
                android:text="Gửi lại mã" />

            <Button
                android:id="@+id/backToLoginButton"
                style="@style/TransferTextButton"
                android:text="Quay về đăng nhập" />
        </LinearLayout>

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/main_notification_bg"
            android:lineSpacingExtra="4dp"
            android:minHeight="64dp"
            android:padding="15dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
