<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView style="@style/MutedText" android:text="Đăng nhập nhanh" />

        <TextView
            android:id="@+id/greetingText"
            style="@style/PageTitle"
            android:layout_marginTop="2dp"
            android:text="Xin chào" />

        <TextView
            style="@style/MutedText"
            android:layout_marginTop="8dp"
            android:text="Nhập mật khẩu để tiếp tục phiên demo. Ứng dụng vẫn kiểm tra tài khoản qua backend trước khi vào Dashboard." />

        <LinearLayout
            style="@style/Panel"
            android:orientation="vertical">

            <TextView
                style="@style/FieldLabel"
                android:text="Mật khẩu" />

            <EditText
                android:id="@+id/passwordInput"
                style="@style/Input"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/loginButton"
                style="@style/PrimaryButton"
                android:text="Đăng nhập" />
        </LinearLayout>

        <Button
            android:id="@+id/otherAccountButton"
            style="@style/SecondaryButton"
            android:text="Tài khoản khác" />

        <Button
            android:id="@+id/forgotPasswordButton"
            style="@style/SecondaryButton"
            android:text="Quên mật khẩu?" />

        <TextView
            android:id="@+id/resultText"
            style="@style/ResultBox"
            android:text="Tài khoản đã được nhớ, nhưng cần xác thực lại trước khi vào Dashboard." />
    </LinearLayout>
</ScrollView>
