<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        style="@style/ScreenRoot"
        android:paddingTop="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/BrandMark"
                android:text="NLU" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="NLU Banking"
                    android:textColor="@color/bank_navy"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ngân hàng số cho sinh viên NLU"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/hero_card_bg"
            android:elevation="6dp"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Quản lý tài chính hằng ngày"
                android:textColor="@color/text_on_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Mở tài khoản, theo dõi số dư, chuyển tiền và xem lịch sử giao dịch trong một trải nghiệm rõ ràng."
                android:textColor="@color/text_on_primary_muted"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/loginButton"
            style="@style/PrimaryButton"
            android:layout_marginTop="20dp"
            android:text="Đăng nhập" />

        <Button
            android:id="@+id/openAccountButton"
            style="@style/SecondaryButton"
            android:text="Tạo hồ sơ khách hàng" />

        <TextView
            style="@style/SectionTitle"
            android:layout_marginTop="24dp"
            android:text="Dịch vụ nhanh" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/helpShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Hỗ trợ" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/rateShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Tỷ giá" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/branchShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Điểm GD" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
