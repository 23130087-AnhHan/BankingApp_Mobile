<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_nlubank"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo + tên app + nút bên phải -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/logoLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:contentDescription="NLU Bank"
                    android:scaleType="centerInside"
                    android:src="@drawable/nlu_logo" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="NLU Bank"
                        android:textColor="@color/text_on_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Ngân hàng số cho sinh viên NLU"
                        android:textColor="@color/nlu_mint"
                        android:textSize="13sp" />

                </LinearLayout>
            </LinearLayout>

            <!-- Cờ Việt Nam hình tròn -->
            <ImageButton
                android:id="@+id/btnLanguage"
                android:layout_width="60dp"
                android:layout_height="57dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_circle_white"
                android:padding="3dp"
                android:src="@drawable/ic_flag_vn"
                android:scaleType="centerCrop"
                android:contentDescription="Language" />

            <!-- Hỗ trợ -->
            <ImageButton
                android:id="@+id/btnSupport"
                android:layout_width="80dp"
                android:layout_height="60dp"
                android:layout_below="@id/btnLanguage"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-6dp"
                android:layout_marginEnd="-11dp"
                android:background="@android:color/transparent"
                android:contentDescription="Support"
                android:scaleType="centerInside"
                android:src="@drawable/ic_support" />

        </RelativeLayout>

        <Space
            android:layout_width="1dp"
            android:layout_height="210dp" />

        <!-- Form đăng nhập -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="370dp"
            android:background="@drawable/welcome_glass_panel"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chào mừng bạn"
                android:textColor="@color/text_on_primary"
                android:textSize="23sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="đến với "
                    android:textColor="@color/text_on_primary"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NLU Bank"
                    android:textColor="@color/nlu_mint"
                    android:textSize="23sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:background="@android:color/transparent"
                android:hint="Tên đăng nhập"
                android:inputType="text"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@android:color/white"
                android:textColorHint="#90FFFFFF"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#55FFFFFF" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@android:color/white"
                android:textColorHint="#90FFFFFF"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#55FFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtRegister"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tạo tài khoản"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quên mật khẩu?"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </LinearLayout>

            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/welcome_brand_badge"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="Đăng nhập"
                android:textAllCaps="false"
                android:textColor="@color/nlu_green_deep"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/verifyEmailButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                android:text="Xác thực email"
                android:textAllCaps="false"
                android:textColor="@color/nlu_mint"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/nlu_mint"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">


        </LinearLayout>

    </LinearLayout>

</ScrollView>
