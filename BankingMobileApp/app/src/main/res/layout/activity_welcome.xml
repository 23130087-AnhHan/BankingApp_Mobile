<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/balance_card_bg"
            android:elevation="8dp"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Banking Demo"
                android:textColor="@color/text_on_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Quản lý tài khoản, giao dịch và chuyển tiền trong một trải nghiệm mobile banking đơn giản."
                android:textColor="@color/text_on_primary_muted"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/loginButton"
            style="@style/PrimaryButton"
            android:layout_marginTop="22dp"
            android:text="Đăng nhập" />

        <Button
            android:id="@+id/openAccountButton"
            style="@style/SecondaryButton"
            android:text="Chưa có tài khoản? Mở tài khoản" />

        <TextView
            style="@style/SectionTitle"
            android:layout_marginTop="26dp"
            android:text="Dịch vụ nhanh" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/helpShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Trợ giúp" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/rateShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Tỷ giá" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/branchShortcut"
                style="@style/ActionTile"
                android:layout_weight="1"
                android:text="Điểm GD" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
